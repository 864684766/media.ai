# =============================================================================
# lanmo 环境变量模板 · 复制为 .env 后修改
# =============================================================================
# 【管什么】FastAPI 服务如何启动：端口、调试、日志、API 前缀
# 【不管什么】Agent 检索条数、Profile 套餐 → 见 config/app.yaml
# 【谁修改】开发者/部署人员；改 .env 后需重启服务
# 【读取代码】app/core/config.py（pydantic-settings）
# =============================================================================

# APP_NAME · 应用名称，显示在日志与 /docs 标题
# 示例: APP_NAME=lanmo
APP_NAME=lanmo

# APP_ENV · 运行环境标识
# 可选: development | production
# 示例: APP_ENV=production
APP_ENV=development

# APP_DEBUG · 是否调试模式（true 时错误信息更详细，生产建议 false）
# 示例: APP_DEBUG=false
APP_DEBUG=true

# APP_HOST · 监听地址；0.0.0.0 表示允许局域网访问
# 示例: APP_HOST=127.0.0.1  仅本机
APP_HOST=0.0.0.0

# APP_PORT · 服务端口
# 示例: APP_PORT=8000
APP_PORT=8000

# APP_API_PREFIX · 所有 API 路由前缀
# 示例: APP_API_PREFIX=/api/v1  → chat 为 /api/v1/chat
APP_API_PREFIX=/api/v1

# LOG_LEVEL · 日志详细程度
# 可选: DEBUG | INFO | WARNING | ERROR
# 示例: LOG_LEVEL=DEBUG  开发排查时用
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# CORS · 前端跨域（media-web 工作台）
# -----------------------------------------------------------------------------
# CORS_ORIGINS · 允许的前端源，逗号分隔
# 示例: CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 读取代码：app/core/cors_settings.py
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# PostgreSQL · 业务真相源（会话、消息、文档）· app/storage/postgres/
# -----------------------------------------------------------------------------
# DATABASE_URL · SQLAlchemy 连接串
# 示例: DATABASE_URL=postgresql+psycopg://lanmo:lanmo@127.0.0.1:5432/lanmo
# 未配置时：存储帮助类仍可 import，health 返回「未配置」不报错
# DATABASE_URL=postgresql+psycopg://user:pass@127.0.0.1:5432/lanmo
#
# 建表（推荐）：poetry run alembic upgrade head
# 已有 create_all 的库可：poetry run alembic stamp head 后再 upgrade
# 详见 docs/index.html 与 alembic/versions/

# -----------------------------------------------------------------------------
# Neo4j · 知识图谱索引（Phase 2 检索）· app/storage/neo4j/
# -----------------------------------------------------------------------------
# NEO4J_URI · Bolt 地址
# 示例: NEO4J_URI=bolt://127.0.0.1:7687
# 注意: http://host:7474/browser/ 是 Neo4j Browser 网页，不是程序连接地址
# 程序连接通常使用 bolt://host:7687
# NEO4J_USER · 默认 neo4j
# NEO4J_PASSWORD · 社区版安装时设置的密码
# NEO4J_URI=bolt://127.0.0.1:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-password

# -----------------------------------------------------------------------------
# LLM Provider · 大模型 API Key · app/providers/
# -----------------------------------------------------------------------------
# ZHIPU_API_KEY · 智谱 GLM 密钥；config/app.yaml 中 model.provider=zhipu 时使用
# 示例: ZHIPU_API_KEY=sk-xxxxxxxx
# DEEPSEEK_API_KEY · DeepSeek 密钥；provider=deepseek 时使用
# KIMI_API_KEY · Kimi / Moonshot 密钥；provider=kimi 时使用
# 说明：密钥一律放 .env，不写入 config/app.yaml，不提交真实值
# ZHIPU_API_KEY=your-key-here
# DEEPSEEK_API_KEY=your-key-here
# KIMI_API_KEY=your-key-here

# -----------------------------------------------------------------------------
# Web 搜索 · Tavily API Key · app/retrieval/web_search.py
# -----------------------------------------------------------------------------
# TAVILY_API_KEY · 联网搜索密钥；config/app.yaml 中 web_search.provider=tavily 时使用
# 未配置时：needs_web / Grader 兜底不联网，返回空结果，主流程不受影响
# 示例: TAVILY_API_KEY=tvly-xxxxxxxx
# TAVILY_API_KEY=your-key-here

# -----------------------------------------------------------------------------
# 视频生产线 · ffmpeg（Phase V · V7 local_ffmpeg Provider）
# -----------------------------------------------------------------------------
# FFMPEG_PATH · ffmpeg 可执行文件绝对路径；未设置时从系统 PATH 查找
# 用于 video.providers.active.clip=local_ffmpeg 与 compose=local_ffmpeg
# 示例: FFMPEG_PATH=C:/ffmpeg/bin/ffmpeg.exe
# FFMPEG_PATH=
#
# 视频音频 TTS（V8.5 · 真实音视频）
# video.audio.tts_provider 在 config/app.yaml 配置
#   stub      → 静音 WAV（演示）
#   edge_tts  → 微软 Edge 在线语音（需外网；poetry install 已含 edge-tts）
# 未安装 edge-tts 或网络失败时自动回退 stub 并写日志
#
# 真实 mp4 成片还需 config/app.yaml：
#   video.providers.active.clip=local_ffmpeg
#   video.providers.active.compose=local_ffmpeg
# 详见 docs/index.html#sec-real-av
